{
  "name": "opencode-alchemyst-context",
  "version": "0.1.0",
  "description": "opencode plugin for AlchemystAI Context Layer — persistent, retrievable memory for coding sessions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.0",
    "@types/node": "^26.1.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "opencode",
    "plugin",
    "alchemyst",
    "context",
    "memory",
    "ai"
  ],
  "license": "MIT"
}
